# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Backend server
PORT=3215
CORS_ORIGIN="http://localhost:5173"
VITE_API_BASE_URL="http://localhost:3215/api"
VITE_BACKEND_URL="http://localhost:3215"
ENABLE_DEV_AUTH="false"
VITE_ENABLE_DEV_AUTH="false"

# PostgreSQL. When DATABASE_URL is set, the backend uses PostgreSQL unless ENABLE_MEMORY_STORE="true".
DATABASE_URL="postgresql://postgres:password@localhost:5432/election_system"
JWT_SECRET="change-this-secret"
ENABLE_MEMORY_STORE="false"
GOOGLE_CLIENT_ID=""
VITE_GOOGLE_CLIENT_ID=""

# Firebase Admin SDK for backend.
# Use either GOOGLE_APPLICATION_CREDENTIALS pointing to a service account file:
# GOOGLE_APPLICATION_CREDENTIALS="C:/path/to/firebase-service-account.json"
#
# Or paste the full service account JSON as one line:
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"..."}'
